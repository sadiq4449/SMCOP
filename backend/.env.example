DATABASE_URL=postgresql+psycopg2://smocp:smocp@localhost:5432/smocp
# Supabase (Settings > Database): use the URI, optionally with ?sslmode=require
# Prefer Session pooler (port 6543) for serverless. Either form works — the app adds +psycopg2 and SSL for *.supabase.co.
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Local fallback without PostgreSQL:
# DATABASE_URL=sqlite:///./smocp_dev.db
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173
# Single Vercel deploy (FastAPI serves Vite build): same-origin browser calls — set your prod URL if you use cookies across subdomains.
# Split deploy (frontend on Vercel only): comma-separated origins, e.g. https://your-app.vercel.app
ENVIRONMENT=development
SEED_DEMO_USERS=true
