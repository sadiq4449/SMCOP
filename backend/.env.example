# Any one of these names is read by the app (same Postgres URI):
DATABASE_URL=postgresql+psycopg2://smocp:smocp@localhost:5432/smocp
# Vercel + Supabase integration often injects POSTGRES_URL / POSTGRES_PRISMA_URL — those work too.
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Supabase Dashboard: Project Settings → Database → Connection string → URI.
# Session pooler (port 6543) fits Vercel/serverless. Direct (5432) is fine for local Alembic.
# Optional tables bootstrap without Alembic: run supabase/000_schema_from_alembic.sql in SQL Editor.
# Local fallback without PostgreSQL:
# DATABASE_URL=sqlite:///./smocp_dev.db
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Comma-separated. Add every URL where the SPA runs (Vercel production + preview + local Vite).
# Vercel: Project → Settings → Environment Variables → CORS_ORIGINS (Production / Preview), then Redeploy.
# Example: CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app,https://your-git-branch-team.vercel.app
# List each origin exactly (no * wildcards). Preview deployments each have their own hostname — add those you use.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENVIRONMENT=development
SEED_DEMO_USERS=true

# Monitoring evidence (Iteration 4): stored under backend/<UPLOAD_DIR>/
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=12
