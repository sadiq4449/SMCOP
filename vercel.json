{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "other",
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/health/schema", "destination": "/api/index" },
    { "source": "/health/db", "destination": "/api/index" },
    { "source": "/health/env", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/docs", "destination": "/api/index" },
    { "source": "/openapi.json", "destination": "/api/index" },
    { "source": "/redoc", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
