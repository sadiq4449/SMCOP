{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build && mkdir -p ../public && find ../public -mindepth 1 -delete && cp -r dist/. ../public/",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/svc/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "private, no-store, must-revalidate" }]
    },
    {
      "source": "/health/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "private, no-store, must-revalidate" }]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "private, no-store, must-revalidate" }]
    },
    {
      "source": "/docs",
      "headers": [{ "key": "Cache-Control", "value": "private, no-store, must-revalidate" }]
    },
    {
      "source": "/openapi.json",
      "headers": [{ "key": "Cache-Control", "value": "private, no-store, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/svc/(.*)", "destination": "/api/index" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/health/schema", "destination": "/api/index" },
    { "source": "/health/db", "destination": "/api/index" },
    { "source": "/health/env", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/docs", "destination": "/api/index" },
    { "source": "/openapi.json", "destination": "/api/index" },
    { "source": "/redoc", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
