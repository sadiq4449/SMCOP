{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/svc/(.*)",
      "headers": { "cache-control": "private, no-store, must-revalidate" },
      "continue": true
    },
    {
      "src": "/health/(.*)",
      "headers": { "cache-control": "private, no-store, must-revalidate" },
      "continue": true
    },
    {
      "src": "/api/(.*)",
      "headers": { "cache-control": "private, no-store, must-revalidate" },
      "continue": true
    },
    {
      "src": "/docs",
      "headers": { "cache-control": "private, no-store, must-revalidate" },
      "continue": true
    },
    {
      "src": "/openapi.json",
      "headers": { "cache-control": "private, no-store, must-revalidate" },
      "continue": true
    },
    { "src": "/svc/(.*)", "dest": "/api/index.py" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/health/schema", "dest": "/api/index.py" },
    { "src": "/health/db", "dest": "/api/index.py" },
    { "src": "/health/env", "dest": "/api/index.py" },
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/docs", "dest": "/api/index.py" },
    { "src": "/openapi.json", "dest": "/api/index.py" },
    { "src": "/redoc", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
