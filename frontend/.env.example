# Local only: proxied `/api/v1/*` hits FastAPI (see vite.config.ts).
# Production on Vercel: omit VITE_* so the app uses `/svc/v1`; or set the full prefix, e.g.
# https://YOUR_DEPLOYMENT.vercel.app/svc/v1 — not the bare site URL (login would POST `/auth/*` and return 405).
VITE_API_BASE_URL=http://localhost:8000/api/v1
